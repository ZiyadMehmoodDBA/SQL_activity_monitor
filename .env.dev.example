# Development environment — point at a NON-PRODUCTION SQL Server instance
# Copy to .env.dev and use for local testing / AI-assisted development
# Per devInstruction.md: "Restrict AI access to non-production systems"

DB_SERVER=localhost\SQLEXPRESS
DB_NAME=master

# AUTH_TYPE: "windows" or "sql"
AUTH_TYPE=windows

# Only required when AUTH_TYPE=sql
DB_USER=
DB_PASS=

PORT=3001
POLL_INTERVAL_MS=5000

# Kill allowed in dev — still requires checkbox confirmation in UI
ALLOW_KILL=true
