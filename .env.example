# SQL Server connection
DB_SERVER=HCMPSDB01\HCMPS
DB_NAME=master

# AUTH_TYPE: "windows" (integrated/trusted) or "sql" (username + password)
AUTH_TYPE=windows

# Only required when AUTH_TYPE=sql
DB_USER=
DB_PASS=

# Optional
PORT=3000
POLL_INTERVAL_MS=2000

# Bind address. Defaults to 127.0.0.1 (localhost-only) because the API has no
# authentication — do NOT expose beyond loopback unless behind a trusted
# network or authenticating reverse proxy.
# HOST=127.0.0.1

# Kill session endpoints are DISABLED by default.
# Set to true only after manual review and on non-production or authorized production instances.
# See devInstruction.md — "Do not run destructive SQL from AI generated scripts"
ALLOW_KILL=false

# SQL Agent job start/stop endpoints are DISABLED by default.
# Set to true only on instances where remote job control is authorized.
ALLOW_JOB_CONTROL=false

# NOTE: If Windows auth fails with Tedious driver, install msnodesqlv8:
#   npm install msnodesqlv8
# Then set: AUTH_TYPE=windows-native
# Requires SQL Server Native Client or ODBC Driver for SQL Server to be installed.
